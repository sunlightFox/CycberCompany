{
  "capabilities": {workflow_capabilities_json},
  "real_browser_workflow": {real_browser_workflow_json},
  "provider_mode": "playwright",
  "publish_flow": {
    "start_url": "{publish_url}",
    "wait_until": "{publish_wait_until}",
    "publish_success_text": "{publish_success_text}",
    "upload_success_text": "{upload_success_text}",
    "verify": {
      "expected_url": "{target_post_url}"
    },
    "selectors": {
      "title": "{publish_title_selector}",
      "body": "{publish_body_selector}",
      "submit": "{publish_submit_selector}",
      "form": "{publish_form_selector}",
      "upload": "{publish_upload_selector}"
    }
  },
  "post_publish_identity": {
    "capture_post_identity": true
  },
  "comment_flow": {
    "start_url": "{comment_start_url}",
    "target_post_url": "{target_post_url}",
    "comment_success_text": "{comment_success_text}",
    "recheck_wait_text": "{comment_recheck_wait_text}",
    "verify": {
      "expected_url": "{target_post_url}"
    },
    "selectors": {
      "comment_box": "{comment_box_selector}",
      "comment_input": "{comment_input_selector}",
      "comment_submit": "{comment_submit_selector}",
      "comment_form": "{comment_form_selector}"
    }
  },
  "verification": {
    "require_post_identity": true,
    "proof_source": "page_text"
  }
}
