CYCBER_ROOT=.
CYCBER_DATA_DIR=./data
CYCBER_API_HOST=127.0.0.1
CYCBER_API_PORT=8765

# Optional: reuse an installed Chrome/Edge browser for Playwright screenshots.
# This avoids downloading Playwright-managed Chromium in rate-limited networks.
CYCBER_BROWSER_EXECUTABLE_PATH=
CYCBER_BROWSER_CHANNEL=
