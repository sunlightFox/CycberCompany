CYCBER_ROOT=.
CYCBER_DATA_DIR=./data
CYCBER_API_HOST=127.0.0.1
CYCBER_API_PORT=8765

# Default managed brain:
# - provider: openai_compatible
# - endpoint/model/wire API: read from ~/.codex/config.toml when available
# - api key: read from codex-auth://OPENAI_API_KEY (~/.codex/auth.json)
OPENAI_API_KEY=

# Optional: override the managed default brain endpoint/model without changing code.
CYCBER_REAL_MODEL_ENDPOINT=
CYCBER_REAL_MODEL_MODEL=

# Optional: reuse an installed Chrome/Edge browser for Playwright screenshots.
# This avoids downloading Playwright-managed Chromium in rate-limited networks.
CYCBER_BROWSER_EXECUTABLE_PATH=
CYCBER_BROWSER_CHANNEL=
